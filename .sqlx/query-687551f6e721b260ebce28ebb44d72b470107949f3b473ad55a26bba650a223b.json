{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT o.id, o.name, o.slug, o.is_personal, o.settings, o.created_at, o.updated_at,\n               m.role AS \"role: OrgRole\"\n        FROM organizations o\n        JOIN org_members m ON m.org_id = o.id\n        WHERE m.user_id = $1\n        ORDER BY o.created_at ASC\n        ",
