{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT c.id, c.provider, c.name, c.timezone, c.sync_enabled,\n               s.last_synced_at\n        FROM calendars c\n        LEFT JOIN sync_state s ON s.calendar_id = c.id\n        WHERE c.org_id = $1 AND c.user_id = $2\n        ORDER BY c.is_primary DESC, c.name ASC\n        ",
