  "query": "\n        INSERT INTO org_members (org_id, user_id, role)\n        VALUES ($1, $2, $3)\n        ON CONFLICT (org_id, user_id) DO UPDATE SET role = EXCLUDED.role, updated_at = now()\n        RETURNING id, org_id, user_id, role AS \"role: OrgRole\", created_at, updated_at\n        ",
