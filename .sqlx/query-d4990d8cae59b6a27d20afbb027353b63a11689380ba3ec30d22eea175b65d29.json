{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id, u.email, u.display_name, u.provider, u.system_admin,\n               m.role AS \"role: OrgRole\"\n        FROM org_members m\n        JOIN users u ON u.id = m.user_id\n        WHERE m.org_id = $1\n        ORDER BY m.created_at ASC\n        ",
